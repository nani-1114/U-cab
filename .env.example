# ================================
# UCAB BACKEND - ENVIRONMENT VARS
# ================================

# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.example.mongodb.net/ucab_db?retryWrites=true&w=majority

# CORS
CORS_ORIGIN=https://your-frontend.vercel.app

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this
JWT_EXPIRES_IN=7d

# Admin Seed Credentials (used only if you seed an admin manually)
ADMIN_EMAIL=admin@ucab.com
ADMIN_PASSWORD=Admin@123

# Base fare config (used by fare calculator utility)
BASE_FARE=50
PER_KM_RATE=12
PER_MIN_RATE=2
